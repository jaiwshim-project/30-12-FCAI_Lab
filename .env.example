# ============================================================
# 미래역량AI연구소 학습 플랫폼 — 환경변수 템플릿
# 이 파일을 복사하여 .env 를 만들고 실제 값을 입력하세요.
# .env 는 절대 git에 커밋하지 마세요!
# ============================================================

# Supabase 프로젝트 URL (예: https://abcdefghijkl.supabase.co)
SUPABASE_URL=https://your-project.supabase.co

# Supabase 공개 Anon Key (프론트엔드에서 사용)
SUPABASE_ANON_KEY=your-anon-key

# Supabase 서비스 롤 키 (서버/업로드 스크립트 전용 — 절대 공개 금지)
SUPABASE_SERVICE_KEY=your-service-role-key

# Google Gemini API Key
GEMINI_API_KEY=your-gemini-api-key

# YouTube Data API v3 Key (이미 설정됨)
YOUTUBE_API_KEY=AIzaSyBr67zJBqDYm6dTN9ZvapRjSKxJe0mCJMQ
